# Database (Supabase — Transaction mode pooler for runtime, URL-encode special chars in password)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:6543/postgres?pgbouncer=true"
# Direct connection for Prisma migrations
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres"

# Supabase client (public)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_ID].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_..."

# LINE LIFF
NEXT_PUBLIC_LIFF_ID="your_liff_id_here"

# LearnHouse backend URL
NEXT_PUBLIC_LEARNHOUSE_BACKEND_URL="http://localhost:1338"

# AI Assistant (Gemini) — optional
GOOGLE_GEMINI_API_KEY="your_gemini_api_key_here"
